{
    "name": "flight-control/backend",
    "description": "PHP backend for flight control software",
    "type": "project",
    "require": {
        "php": ">=8.2.0",
        "cboden/ratchet": "^0.4.4",
        "firebase/php-jwt": "^6.10",
        "predis/predis": "^2.2",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
